generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum AutomationMode {
  MANUAL
  SEMI_AUTO
  AUTO
}

enum ReviewResponseStatus {
  PENDING
  GENERATED
  APPROVED
  PUBLISHED
  REJECTED
}

enum ResponseStatus {
  DRAFT
  APPROVED
  PUBLISHED
  REJECTED
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  plan         Plan          @default(FREE)
  googleId     String?       @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  businesses   Business[]
  googleTokens GoogleToken[]
  auditLogs    AuditLog[]

  @@map("users")
}

model Business {
  id                       String         @id @default(uuid())
  userId                   String
  name                     String
  segment                  String?
  city                     String?
  googleProfileId          String?        @unique
  toneOfVoice              String?
  keywords                 String[]       @default([])
  mainServices             String[]       @default([])
  whatsapp                 String?
  defaultResolutionMessage String?
  avoidTerms               String[]       @default([])
  responseTemplate         String?
  automationMode           AutomationMode @default(MANUAL)
  isActive                 Boolean        @default(true)
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews Review[]

  @@index([userId])
  @@map("businesses")
}

model Review {
  id             String               @id @default(uuid())
  businessId     String
  googleReviewId String?              @unique
  reviewerName   String
  rating         Int
  comment        String?
  reviewDate     DateTime
  responseStatus ReviewResponseStatus @default(PENDING)
  createdAt      DateTime             @default(now())

  business  Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  responses Response[]

  @@index([businessId])
  @@index([responseStatus])
  @@map("reviews")
}

model Response {
  id            String         @id @default(uuid())
  reviewId      String
  generatedText String
  publishedText String?
  status        ResponseStatus @default(DRAFT)
  publishedAt   DateTime?
  createdAt     DateTime       @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("responses")
}

model GoogleToken {
  id           String   @id @default(uuid())
  userId       String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("google_tokens")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  details   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
