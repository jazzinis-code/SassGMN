# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/google_reviews

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4

# App
PORT=3001
FRONTEND_URL=http://localhost:3000

# CRON — Sincronização automática de avaliações
# Formato cron: minuto hora dia-do-mês mês dia-da-semana
# Padrão: a cada 6h (00:00, 06:00, 12:00, 18:00 horário de Brasília)
REVIEWS_SYNC_CRON=0 0,6,12,18 * * *
